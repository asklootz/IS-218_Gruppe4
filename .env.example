# Prefer one full Postgres connection string
DATABASE_URL=postgresql://postgres:REPLACE_ME@dbhost:5432/yourdb

# Set to true when your provider requires TLS (e.g. Supabase)
DB_SSL=true

# Optional fallback variables if DATABASE_URL is not used
PGHOST=localhost
PGPORT=5432
PGDATABASE=gis
PGUSER=postgres
PGPASSWORD=REPLACE_ME


